# Per-clone branding — applied to business_settings via `php artisan site:brand`
# SITE_THEME must match a folder under resources/views/frontend/
# (built-in: classic, megamart, metro, minima, nexa, thecore, reclassic)
SITE_THEME="classic"
SITE_NAME=""
SITE_LOGO_HEADER=""
SITE_LOGO_FOOTER=""
SITE_LOGO_BLACK=""
SITE_LOGO_WHITE=""
SITE_PRIMARY_COLOR=""
SITE_SECONDARY_COLOR=""
SITE_CONTACT_EMAIL=""
SITE_CONTACT_PHONE=""
SITE_CONTACT_ADDRESS=""
SITE_FACEBOOK_LINK=""
SITE_META_TITLE=""
SITE_META_DESCRIPTION=""
SITE_META_KEYWORDS=""

# Feature flags — disable modules this clone doesn't need (config/features.php)
FEATURE_MULTIVENDOR="true"
FEATURE_AUCTION="true"
FEATURE_WHOLESALE="true"
FEATURE_AFFILIATE="true"
FEATURE_POS="true"
FEATURE_PREORDER="true"
FEATURE_CLUB_POINTS="true"
FEATURE_DELIVERY_BOY="true"
FEATURE_REFUND_REQUEST="true"

# Install-time only, used by `php artisan site:install` (see config/site_provision.php)
SITE_ADMIN_NAME="Admin"
SITE_ADMIN_EMAIL=""
SITE_ADMIN_PASSWORD=""
SITE_DEFAULT_CURRENCY_CODE="USD"

# LicenseBox (self-hosted, license.fikirmeclisi.com) — one product for the
# whole base template, one activation per site clone. product_id/api_url
# are constant across clones (defaulted in config/license.php); api_key is
# an account-wide credential from LicenseBox Settings > API Settings;
# code/client_name are unique per site clone (client_name is typically
# this site's domain).
LICENSE_API_URL="https://license.fikirmeclisi.com/"
LICENSE_PRODUCT_ID="BF5645A8"
LICENSE_API_KEY=""
LICENSE_CODE=""
LICENSE_CLIENT_NAME=""
LICENSE_VERIFY_PERIOD_DAYS="3"

